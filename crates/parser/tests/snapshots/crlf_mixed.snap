SourceFile {
    shebang: none,
    items: [
        Entry {
            key: WordKey {
                word: WORD@0..1 "a",
            },
            value: LineString {
                string: STRING@2..3 "1",
            },
        },
        Entry {
            key: WordKey {
                word: WORD@5..6 "b",
            },
            value: Integer {
                sign: none,
                numeral: NUMERAL@7..8 "2",
            },
        },
        Entry {
            key: WordKey {
                word: WORD@9..10 "c",
