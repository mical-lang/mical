    SPACE@13..14 " "
    WORD@14..21 "between"
  NEWLINE@21..22 "\n"
  PREFIX_BLOCK@22..34
    WORD_KEY@22..23
      WORD@22..23 "b"
    SPACE@23..24 " "
    OPEN_BRACE@24..25 "{"
    NEWLINE@25..26 "\n"
    SPACE@26..28 "  "
    ENTRY@28..32
